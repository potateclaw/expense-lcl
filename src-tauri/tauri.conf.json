{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Budgy",
  "version": "0.1.0",
  "identifier": "com.budgy.app",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Budgy",
        "url": "index.html",
        "width": 390,
        "height": 844,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 26
    }
  }
}
